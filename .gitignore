# Dependencies
node_modules/

# Downloaded toolchain Release assets (binaries, skills, visualizer, wire-types)
dist-assets/

# VS Code extension build artifacts (staged/compiled at publish time)
packages/vscode/out/
packages/vscode/dist/
packages/vscode/bin/
packages/vscode/skills/
*.vsix

# Claude Code plugin payload — staged from the downloaded skills tarball
packages/npm/claude-plugin/skills/

# Composed package READMEs — generated build output (render-docs). Canonical
# source is the toolchain doc fragments + docs/templates/ here. Never hand-edit.
packages/vscode/README.md
packages/npm/twf/README.md
packages/pypi/twf-cli/README.md
packages/npm/claude-plugin/README.md

# npm platform sub-package binaries (staged at publish time)
packages/npm/twf-*/bin/twf
packages/npm/twf-*/bin/twf.exe

# LICENSE copies generated by package prepack hooks (canonical copy at repo root)
packages/npm/twf*/LICENSE
packages/npm/claude-plugin/LICENSE

# PyPI build output + staged binary
packages/pypi/twf-cli/dist/
packages/pypi/twf-cli/src/twf_cli/_binary/

# bump-brew compiled binary
internal/release/bump-brew/bump-brew
