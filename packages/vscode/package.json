{
  "name": "twf-syntax",
  "displayName": "Temporal Architect",
  "description": "Design, visualize, and implement entire Temporal systems in `.twf` — namespaces, workers, workflows, and Nexus — with a deterministic language server and an interactive architecture visualizer. Covers activities, child workflows, signals, queries, updates, timers, promises, and Nexus.",
  "version": "0.8.4",
  "publisher": "jmbarzee",
  "license": "MIT",
  "homepage": "https://github.com/jmbarzee/temporal-architect",
  "repository": {
    "type": "git",
    "url": "https://github.com/jmbarzee/temporal-architect-dist",
    "directory": "packages/vscode"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "temporal",
    "workflow",
    "twf",
    "architecture",
    "system design",
    "deployment topology",
    "durable execution",
    "orchestration",
    "activities",
    "signals",
    "queries",
    "updates",
    "child workflows",
    "timers",
    "promises",
    "nexus",
    "visualization"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "activationEvents": [
    "onLanguage:twf",
    "onStartupFinished"
  ],
  "contributes": {
    "languages": [
      {
        "id": "twf",
        "aliases": [
          "Temporal Workflow",
          "twf"
        ],
        "extensions": [
          ".twf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "twf",
        "scopeName": "source.twf",
        "path": "./syntaxes/twf.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "twf.visualize",
        "title": "Visualize Workflow",
        "category": "TWF",
        "icon": "$(graph)"
      },
      {
        "command": "twf.visualizeFolder",
        "title": "Visualize All Workflows in Folder",
        "category": "TWF",
        "icon": "$(folder)"
      },
      {
        "command": "twf.installSkills",
        "title": "Install Skills",
        "category": "Temporal Architect",
        "icon": "$(lightbulb)"
      },
      {
        "command": "twf.registerMcpServer",
        "title": "Register MCP Server",
        "category": "Temporal Architect",
        "icon": "$(plug)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == twf",
          "command": "twf.visualize",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "when": "resourceLangId == twf",
          "command": "twf.visualize",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceLangId == twf",
          "command": "twf.visualize",
          "group": "navigation"
        },
        {
          "when": "explorerResourceIsFolder",
          "command": "twf.visualizeFolder",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "twf.visualize",
          "when": "resourceLangId == twf"
        },
        {
          "command": "twf.visualizeFolder"
        },
        {
          "command": "twf.installSkills"
        },
        {
          "command": "twf.registerMcpServer"
        }
      ]
    },
    "semanticTokenScopes": [
      {
        "language": "twf",
        "scopes": {
          "type": [
            "storage.type.twf"
          ],
          "function": [
            "entity.name.function.twf"
          ],
          "variable": [
            "variable.other.twf"
          ]
        }
      }
    ],
    "configuration": {
      "title": "TWF Language Server",
      "properties": {
        "twf.lsp.path": {
          "type": "string",
          "default": "",
          "description": "Path to the twf binary. If empty, looks for 'twf' on PATH."
        },
        "twf.parser.path": {
          "type": "string",
          "default": "",
          "description": "Path to the twf parser binary for visualization. If empty, looks for 'parse' on PATH."
        },
        "twf.decompose.ceiling": {
          "type": "number",
          "default": 60,
          "minimum": 0,
          "description": "Complexity ceiling for the chunk-decomposition overlay in the Graph view. Chunks above it are offered division suggestions; 0 disables the overlay. Reload the visualizer after changing."
        },
        "twf.mcp.autoRegister": {
          "type": "boolean",
          "default": true,
          "description": "Automatically register the bundled `twf mcp` server in ~/.cursor/mcp.json on activation so the agent can call the TWF parser tools. A `twf` server you configured yourself is never overwritten. Disable to manage MCP config manually (use the 'Temporal Architect: Register MCP Server' command to register on demand)."
        }
      }
    }
  },
  "configurationDefaults": {
    "editor.tokenColorCustomizations": {
      "textMateRules": [
        {
          "scope": "keyword.control.twf",
          "settings": {
            "foreground": "#569CD6"
          }
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@temporal-architect/wire-types": "0.8.4",
    "@types/node": "^25.2.2",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}